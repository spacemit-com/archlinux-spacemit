# Maintainer: Keith Packard <keithp@keithp.com>

_target=riscv64-unknown-elf
_gcc_ver=14.2.0

pkgname=gcc-${_target}
pkgver=${_gcc_ver}
pkgrel=19
pkgdesc='GCC cross compiler for bare-metal RISC-V processors (both 32-bit and 64-bit)'
arch=('x86_64' 'riscv64')
url='https://gcc.gnu.org/'
license=('GPL-3.0-or-later' 'LGPL-3.0-or-later')
depends=("binutils")
makedepends=(
  'autoconf'
  'bison'
  'dejagnu'
  'flex'
  'gawk'
  'gettext'
  'gmp'
  'libtool'
  'lsb-release'
  'mpc'
  'mpfr'
  'isl'
  'patchutils'
  'sharutils'
  'texinfo'
  'xz'
  'zlib'
)
options=('!emptydirs' '!strip' 'staticlibs' '!lto')

CFLAGS="${CFLAGS//-Werror=format-security/}"
CXXFLAGS="${CXXFLAGS//-Werror=format-security/}"

source=(
  "https://ftp.gnu.org/gnu/gcc/gcc-${_gcc_ver}/gcc-${_gcc_ver}.tar.xz"
  '0001-Ignore-document-errors-during-build.patch'
  '0002-Add-more-multi-lib-for-rv32-and-rv64.patch'
  '0003-riscv-Preserve-qnan-fraction-and-sign.patch'
  '0004-Remove-use-of-include_next-from-c-headers.patch'
)
sha256sums=(
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
  'SKIP'
)

prepare() {
  cd "${srcdir}/gcc-${_gcc_ver}"

  for _p in "${srcdir}"/*.patch; do
    echo "Applying patch $(basename "${_p}")"
    patch -Np1 < "${_p}"
  done
}

build() {
  mkdir -p "${srcdir}/build"
  cd "${srcdir}/build"
  "${srcdir}/gcc-${_gcc_ver}/configure" \
    --enable-languages=c,c++ \
    --prefix=/usr \
    --libdir=/usr/lib \
    --libexecdir=/usr/lib \
    --infodir=/usr/share/info \
    --mandir=/usr/share/man \
    --htmldir=/usr/share/doc/${pkgname}/html \
    --pdfdir=/usr/share/doc/${pkgname}/pdf \
    --bindir=/usr/bin \
    --with-system-zlib \
    --enable-multilib \
    --disable-decimal-float \
    --disable-libffi \
    --disable-libgomp \
    --disable-libmudflap \
    --disable-libquadmath \
    --disable-libssp \
    --disable-libstdcxx-pch \
    --disable-libstdcxx \
    --disable-nls \
    --disable-shared \
    --disable-threads \
    --with-arch=rv64imafdc \
    --enable-tls \
    --target=${_target} \
    --with-gnu-as \
    --with-gnu-ld \
    --with-headers=no \
    --without-newlib \
    "--with-pkgversion=${pkgver}-${pkgrel}" \
    --without-included-gettext \
    SED=/usr/bin/sed \
    SHELL=/bin/sh \
    BASH=/bin/bash \
    CONFIG_SHELL=/bin/bash \
    AR_FOR_TARGET=${_target}-ar \
    AS_FOR_TARGET=${_target}-as \
    LD_FOR_TARGET=${_target}-ld \
    NM_FOR_TARGET=${_target}-nm \
    OBJDUMP_FOR_TARGET=${_target}-objdump \
    RANLIB_FOR_TARGET=${_target}-ranlib \
    READELF_FOR_TARGET=${_target}-readelf \
    STRIP_FOR_TARGET=${_target}-strip \
    CFLAGS_FOR_TARGET='-Os -mcmodel=medany' \
    CXXFLAGS_FOR_TARGET='-Os -mcmodel=medany' \
    INHIBIT_LIBC_CFLAGS="-DUSE_TM_CLONE_REGISTRY=0"

  #make -j"$(nproc)"
  make -j1
}

package() {
  cd "${srcdir}/build"

  make install DESTDIR="${pkgdir}"

  rm -rf "${pkgdir}/usr/share/info"
  rm -rf "${pkgdir}/usr/share/man/man7"
  find "${pkgdir}" -name '*.la' -delete
  rm -f "${pkgdir}/usr/lib/libcc1."*

  install -Dm644 "${srcdir}/gcc-${_gcc_ver}/COPYING3" \
    "${pkgdir}/usr/share/licenses/${pkgname}/COPYING3"
  install -Dm644 "${srcdir}/gcc-${_gcc_ver}/COPYING.LIB" \
    "${pkgdir}/usr/share/licenses/${pkgname}/COPYING.LIB"
}

